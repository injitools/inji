{
  "name": "@injitools/contract",
  "version": "0.1.0",
  "description": "The DTO/validation layer of Inji: RequestDto/ResponseDto decorators, metadata store and Zod validation. Depends only on zod + reflect-metadata — no express or typeorm (layering hygiene).",
  "keywords": [
    "inji",
    "dto",
    "zod",
    "validation",
    "decorators",
    "typescript"
  ],
  "author": "Alexey Krupsky <admin@inji.ru>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
